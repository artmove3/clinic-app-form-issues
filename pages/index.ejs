<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title><%= title %></title>
</head>
<body>
    <% if(created) { %>
        <div class="alert alert-success">
            Note has been created!
        </div>
    <% } %>
   <div class="container">
        <h1><%= title %></h1>
        <form action="/" method="post"">
            <div class="form-group mb-2">
                <input type="text" class="form-control mb-2" name="title" required>
                <button class="btn btn-primary" type="submit">Create!</button>
            </div>
        </form>
        <% if(notes.length) { %>
        
        <div class="card">
            <ul class="list-group">
                <% for(let i = 0; i < notes.length; i++) { %>
                <li class="list-group-item d-flex justify-content-between aling-items-center" value="<%= notes[i].title %>">
                    <%= notes[i].title %>
                    <div class="button-container">
                        <button class="btn btn-primary" data-type="edit" data-id="<%= notes[i].id %>">Редактировать</button>
                        <button class="btn btn-danger" data-type="remove" data-id="<%= notes[i].id %>">&times;</button>
                    </div>
                    
                </li>
                <% } %>
            </ul>
        </div>
        
    
    <% } else { %>
        <p>No notes!</p>
        <% } %>
    </div>
    
    <script src="/app.js"></script>
</body>
</html>
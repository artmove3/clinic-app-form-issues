<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title><%= title %></title>
</head>
<body> 
    
    <%- include('./partials/user-header') %>
    
     

   
    <div class="alert alert-success" id="success" style="visibility: hidden;">
        Запись к врачу подтверждена.
    </div>

    <div class="alert alert-warning" id="warning" style="visibility: hidden;">
        Пожалуйста, заполните все поля формы для создания заявки.
    </div>
      
    <div class="alert alert-danger" id="danger" style="visibility: hidden;">
        Something went wrong!
    </div>
   
   <div class="d-flex flex-column align-items-center my-0 mx-auto w-50">
        <h1><%= title %></h1>
        <form action="/" method="post" class="d-flex flex-column" id="formIssue" style="width: 400px;">
            <div class="form-group mb-2 p-5 d-flex flex-column border border-light-subtle">
                <div class="form-user-name">
                    <label for="userName">ФИО</label>
                    <input type="text" class="form-control mb-2" maxlength="50" name="userName" id="userName" required>
                </div>
                <div class="form-phone-number">
                    <label for="phoneNumber">Номер Телефона</label>
                    <input 
                        type="tel"
                        placeholder="+7 (___) ___-____" 
                        class="form-control mb-2" 
                        name="phoneNumber" 
                        id="phoneNumber" 
                        required
                    >
                </div>
                <div class="form-issue">
                    <label for="issue">Опишите вашу проблему</label>
                    <textarea class="form-control mb-2" maxlength="50" style="min-height: 100px;" name="issue" id="issue"></textarea>
                </div>
                
                <button class="btn btn-secondary" id="submitButton" type="submit">Отправить</button>
            </div>
        </form>   
    </div>
    
    <script src="/app.js"></script>
</body>
</html>
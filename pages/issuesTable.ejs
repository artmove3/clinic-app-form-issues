<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport"
    content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
  <title>
    <%= title %>
  </title>
</head>

<body>
  <div class="d-flex flex-column text-center my-0 mx-auto w-75">
    <h1>Заявки с формы</h1>
    <section class="h-100">
      <% if(issues.length) { %>
      <table class="table text-start" style="max-width: 1200px;">
         <thead>
            <tr>
                <th>Дата отправки</th>
                <th>ФИО</th>
                <th>Телефон</th>
                <th>Проблема</th>
            </tr>
        </thead>
        <tbody>

         
        
                <% for(let i = 0; i < issues.length; i++) { %>
                <tr >
                    <td><%= issues[i].issueData.toLocaleDateString() %></td>
                    <td><%= issues[i].userName %></td>
                    <td><%= issues[i].phoneNumber %></td>
                    <td  style="max-width: 400px;"><%= issues[i].issueText %></td>
                </tr>
                <% } %>
       
        
    
    
        </tbody>
      </table>
      <% } else { %>
        <p>Заявки на данный момент отсутствуют</p>
        <% } %>
    </section>
    </div>
</body>

</html>